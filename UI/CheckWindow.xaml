<Window x:Class="BM_AGR_PARAM.UI.CheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BM AGR Parameter Checker" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="#F5F5F5">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Проверка параметров АГР" FontSize="24" FontWeight="Bold" Foreground="#333"/>
            <TextBlock Text="Список обязательных параметров и их привязка к категориям" Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Margin="0,0,0,10" Padding="15,10" CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5" Opacity="0.1" Direction="270"/>
                            </Border.Effect>
                            
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Колонка 1: Имя параметра -->
                                <TextBlock Grid.Column="0" Text="{Binding Requirement.Name}" 
                                         FontWeight="SemiBold" FontSize="14" 
                                         Foreground="#333" VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Колонка 2: Категории и предупреждения -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                    <TextBlock Text="{Binding Requirement.DisplayCategories}" 
                                             FontSize="11" Foreground="#999" 
                                             TextTrimming="CharacterEllipsis"/>
                                    
                                    <TextBlock Text="{Binding MissingCategoriesDescription}" 
                                             Foreground="#F44336" FontSize="11" 
                                             FontWeight="SemiBold"
                                             Visibility="{Binding HasMissingCategories, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <!-- Колонка 3: Статус (Отсутствует / ОК) -->
                                <Border Grid.Column="2" VerticalAlignment="Center" 
                                        Padding="10,4" CornerRadius="4" 
                                        Background="{Binding StatusColor}"
                                        MinWidth="80">
                                    <TextBlock Text="{Binding StatusText}" 
                                             Foreground="White" FontWeight="Bold" 
                                             FontSize="11" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Проверить наличие" Click="Check_Click" 
                    Padding="20,10" Background="#2196F3" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                </Button.Resources>
            </Button>
            
            <Button Content="Исправить привязки" Click="Fix_Click" 
                    Padding="20,10" Background="#4CAF50" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
